{
	"compatibility_date": "2026-03-16",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "akashm-dev",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "akashm-dev-db",
			"database_id": "8d648b56-c3e0-4123-8054-d53f58b088e5"
		}
	]
}
