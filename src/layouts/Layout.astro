---
import { Font } from 'astro:assets';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title = 'Akash Mahajan — Builder, Security, AI Agents',
  description = 'Founder of Kloudle and Appsecco. Building security tools, AI agents, and open-source projects.',
  canonicalPath,
} = Astro.props;

const canonicalURL = canonicalPath
  ? new URL(canonicalPath, Astro.site)
  : Astro.url;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': 'https://akashm.dev/#person',
      name: 'Akash Mahajan',
      url: 'https://akashm.dev',
      description: 'Security practitioner and founder building cloud security tools, AI agents, and open-source projects.',
      jobTitle: 'Founder',
      knowsAbout: [
        'Cloud Security',
        'Application Security',
        'AI Red Teaming',
        'AI Agents',
        'Penetration Testing',
        'Security Automation',
        'CSPM',
        'MCP Protocol',
      ],
      sameAs: [
        'https://x.com/makash',
        'https://github.com/makash',
        'https://www.linkedin.com/in/akashm/',
        'https://www.youtube.com/@makash',
      ],
      worksFor: [
        { '@id': 'https://akashm.dev/#kloudle' },
        { '@id': 'https://akashm.dev/#appsecco' },
      ],
    },
    {
      '@type': 'Organization',
      '@id': 'https://akashm.dev/#kloudle',
      name: 'Kloudle',
      url: 'https://kloudle.com',
      description: 'Cloud security posture management for the agent era.',
      founder: { '@id': 'https://akashm.dev/#person' },
    },
    {
      '@type': 'Organization',
      '@id': 'https://akashm.dev/#appsecco',
      name: 'Appsecco',
      url: 'https://appsecco.com',
      description: 'Application security consulting and training. From pentesting to AI red teaming.',
      founder: { '@id': 'https://akashm.dev/#person' },
    },
    {
      '@type': 'WebSite',
      '@id': 'https://akashm.dev/#website',
      url: 'https://akashm.dev',
      name: 'Akash Mahajan',
      publisher: { '@id': 'https://akashm.dev/#person' },
    },
  ],
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={new URL('/og-image.svg', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@makash" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.svg', Astro.site).href} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" type="application/rss+xml" title="Akash Mahajan" href="/rss.xml" />
    <title>{title}</title>

    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" preload />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Theme: respect system preference, allow toggle -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        const preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', stored || preferred);
      })();
    </script>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <span class="logo-mark">AM</span>
          <span class="logo-text">Akash Mahajan</span>
        </a>

        <div class="nav-right">
          <a href="/" class="nav-link">Home</a>
          <a href="/about" class="nav-link">About</a>
          <a href="/#projects" class="nav-link">Projects</a>
          <a href="/books" class="nav-link">Books</a>
          <a href="/writing" class="nav-link">Writing</a>
          <a href="/now" class="nav-link">Now</a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
            <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <p class="footer-by">Built by Akash Mahajan</p>
        <div class="footer-social">
          <a href="https://x.com/makash" target="_blank" rel="noopener" aria-label="X / Twitter">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://github.com/makash" target="_blank" rel="noopener" aria-label="GitHub">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/akashm/" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://www.youtube.com/@makash" target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>
    </footer>

    <script>
      // Theme toggle
      const toggle = document.getElementById('theme-toggle');
      toggle?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });

      // Scroll reveal
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });
      reveals.forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  /* ── Design System: High-contrast minimal ── */
  :root,
  [data-theme="dark"] {
    --color-bg: #1a1d23;
    --color-surface: #22252d;
    --color-surface-hover: #2a2d36;
    --color-text: #e8eaed;
    --color-text-dim: #8b8fa3;
    --color-accent: #6366f1;
    --color-accent-hover: #818cf8;
    --color-border: #2e3140;
    --color-border-light: #383c4e;
    --color-tag-bg: #262932;
    --color-tag-text: #9498ad;
  }

  [data-theme="light"] {
    --color-bg: #f1f3f5;
    --color-surface: #ffffff;
    --color-surface-hover: #e9ecef;
    --color-text: #1a1d23;
    --color-text-dim: #5c6070;
    --color-accent: #4f46e5;
    --color-accent-hover: #4338ca;
    --color-border: #dee2e6;
    --color-border-light: #ced4da;
    --color-tag-bg: #e9ecef;
    --color-tag-text: #5c6070;
  }

  :root {
    --max-w: 64rem;
    --gutter: clamp(1.5rem, 5vw, 3.5rem);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    font-feature-settings: 'kern' 1, 'liga' 1;
  }

  body {
    font-family: var(--font-sans), system-ui, -apple-system, sans-serif;
    font-size: clamp(1.0625rem, 1rem + 0.3vw, 1.1875rem);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.75;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    transition: background 0.3s ease, color 0.3s ease;
  }

  h1, h2, h3 {
    font-family: var(--font-display), Georgia, serif;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  h1 { font-weight: 700; }

  code, pre {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-feature-settings: 'liga' 1;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  a:hover { color: var(--color-accent-hover); }

  main { flex: 1; }

  ::selection {
    background: var(--color-accent);
    color: #fff;
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.revealed { opacity: 1; transform: translateY(0); }
  .reveal-d1 { transition-delay: 0.08s; }
  .reveal-d2 { transition-delay: 0.16s; }
  .reveal-d3 { transition-delay: 0.24s; }

  /* Section label */
  .section-label {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }
</style>

<style>
  /* Nav */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: color-mix(in srgb, var(--color-bg) 90%, transparent);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
    transition: background 0.3s;
  }

  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.85rem var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--color-text);
  }
  .nav-logo:hover { color: var(--color-text); }

  .logo-mark {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
    padding: 0.2rem 0.45rem;
    line-height: 1;
  }

  .logo-text {
    font-family: var(--font-display), Georgia, serif;
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-dim);
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--color-text); }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-dim);
    padding: 0.4rem;
    cursor: pointer;
    transition: all 0.15s;
  }
  .theme-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  [data-theme="dark"] .icon-sun { display: block; }
  [data-theme="dark"] .icon-moon { display: none; }
  [data-theme="light"] .icon-sun { display: none; }
  [data-theme="light"] .icon-moon { display: block; }

  /* Footer */
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 4rem var(--gutter) 3rem;
    margin-top: 8rem;
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  .footer-by {
    font-size: 0.875rem;
    color: var(--color-text-dim);
  }

  .footer-social {
    display: flex;
    gap: 1.25rem;
  }

  .footer-social a {
    color: var(--color-text-dim);
    opacity: 0.4;
    transition: all 0.15s;
  }
  .footer-social a:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .nav-link { display: none; }
  }
</style>
