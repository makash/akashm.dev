---
import Layout from '../layouts/Layout.astro';
import { books, newsletters } from '../data/books';
---

<Layout
  title="Books — Akash Mahajan"
  description="Books authored by Akash Mahajan on web security, penetration testing, and security automation."
  canonicalPath="/books"
>
  <section class="books">
    <div class="books-inner">
      <p class="section-label reveal">Books</p>
      <h1 class="books-title reveal reveal-d1">Published work</h1>
      <p class="books-sub reveal reveal-d2">Books on security tooling and automation, published by Packt.</p>

      <div class="book-list">
        {books.map((book, i) => (
          <article class={`book-card reveal reveal-d${Math.min(i + 2, 3)}`}>
            <div class="book-meta">
              <span class="book-year">{book.year}</span>
              <span class="book-role">{book.role}</span>
            </div>

            <h2 class="book-title">{book.title}</h2>
            <p class="book-subtitle">{book.subtitle}</p>

            {book.coAuthors.length > 0 && (
              <p class="book-coauthors">
                with {book.coAuthors.join(', ')}
              </p>
            )}

            <p class="book-desc">{book.description}</p>

            {book.distinction && (
              <p class="book-distinction">{book.distinction}</p>
            )}

            <div class="book-details">
              <span class="book-detail">{book.publisher}</span>
              <span class="book-detail">{book.pages} pages</span>
              <span class="book-detail">{book.isbn}</span>
            </div>

            <div class="book-topics">
              {book.topics.map((topic) => (
                <span class="tag">{topic}</span>
              ))}
            </div>

            <div class="book-links">
              {book.links.map((link) => (
                <a href={link.url} target="_blank" rel="noopener" class="book-link">
                  {link.label} &nearr;
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="newsletters reveal">
        <h2 class="newsletters-heading">Newsletters</h2>
        <div class="newsletter-grid">
          {newsletters.map((nl) => (
            <a href={nl.url} target="_blank" rel="noopener" class="newsletter-card">
              <div class="nl-top">
                <span class="nl-title">{nl.title}</span>
                <span class="nl-platform">{nl.platform}</span>
              </div>
              <p class="nl-desc">{nl.description}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .books { padding: 10rem var(--gutter) 4rem; }

  .books-inner { max-width: var(--max-w); margin: 0 auto; }

  .books-title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .books-sub {
    font-size: 1rem;
    color: var(--color-text-dim);
    margin-bottom: 4rem;
    max-width: 36rem;
  }

  .book-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: 5rem;
  }

  .book-card {
    background: var(--color-surface);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .book-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .book-year {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }

  .book-role {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-dim);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .book-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .book-subtitle {
    font-size: 1rem;
    color: var(--color-text-dim);
    font-style: italic;
    margin-top: -0.5rem;
  }

  .book-coauthors {
    font-size: 0.925rem;
    color: var(--color-text-dim);
  }

  .book-desc {
    font-size: 1rem;
    color: var(--color-text-dim);
    line-height: 1.8;
    max-width: 42rem;
  }

  .book-distinction {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent);
    padding: 0.75rem 1rem;
    border-left: 3px solid var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  .book-details {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .book-detail {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-dim);
    letter-spacing: 0.02em;
  }

  .book-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.65rem;
    font-weight: 500;
    padding: 0.2rem 0.55rem;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
  }

  .book-links {
    display: flex;
    gap: 1.25rem;
    padding-top: 0.5rem;
  }

  .book-link {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-dim);
    transition: color 0.15s;
  }
  .book-link:hover { color: var(--color-accent); }

  /* Newsletters */
  .newsletters-heading {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .newsletter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .newsletter-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.75rem 2rem;
    background: var(--color-surface);
    color: var(--color-text);
    transition: background 0.15s;
  }
  .newsletter-card:hover { background: var(--color-surface-hover); color: var(--color-text); }

  .nl-top {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .nl-title {
    font-family: var(--font-sans), system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .nl-platform {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-text-dim);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .nl-desc {
    font-size: 0.925rem;
    color: var(--color-text-dim);
    line-height: 1.65;
  }

  @media (max-width: 640px) {
    .book-card { padding: 2rem 1.5rem; }
    .book-links { flex-wrap: wrap; gap: 1rem; }
  }
</style>
