---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Writing — Akash Mahajan"
  description="Build logs, security insights, and lessons from shipping in the open."
  canonicalPath="/writing"
>
  <section class="writing">
    <div class="writing-inner">
      <p class="section-label reveal">Writing</p>
      <h1 class="writing-title reveal reveal-d1">Build logs & security insights</h1>
      <p class="writing-sub reveal reveal-d2">Short, raw updates about what I'm shipping, breaking, and learning.</p>

      {posts.length > 0 ? (
        <div class="post-list">
          {posts.map((post) => (
            <a href={`/writing/${post.id}`} class="post-card reveal">
              <time class="post-date" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <div class="post-tags">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty reveal reveal-d2">
          <p>No posts yet. Check back soon — I'm bringing all my writing here.</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .writing { padding: 10rem var(--gutter) 4rem; }

  .writing-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .writing-title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .writing-sub {
    font-size: 1rem;
    color: var(--color-text-dim);
    margin-bottom: 3rem;
    max-width: 36rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 1.75rem;
    background: var(--color-surface);
    color: var(--color-text);
    transition: background 0.3s;
  }
  .post-card:hover { background: var(--color-surface-hover); color: var(--color-text); }

  .post-date {
    font-family: var(--font-mono), monospace;
    font-size: 0.7rem;
    color: var(--color-text-dim);
    letter-spacing: 0.04em;
  }

  .post-title {
    font-family: var(--font-sans), system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .post-desc {
    font-size: 0.9rem;
    color: var(--color-text-dim);
    line-height: 1.6;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-family: var(--font-mono), monospace;
    font-size: 0.65rem;
    padding: 0.2rem 0.55rem;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    border-radius: 4px;
  }

  .empty {
    padding: 3rem 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-align: center;
  }

  .empty p {
    font-size: 1rem;
    color: var(--color-text-dim);
  }
</style>
