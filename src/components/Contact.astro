---

---

<section class="contact" id="contact">
  <div class="contact-inner">
    <div class="contact-card reveal">
      <p class="section-label">Say hello</p>
      <h2 class="contact-heading">I like hearing from people who build things.</h2>
      <p class="contact-sub">Fastest way is a DM on X. I read everything.</p>

      <div class="contact-quick">
        <a href="https://x.com/makash" target="_blank" rel="noopener" class="dm-btn">DM @makash on X &nearr;</a>
        <a href="mailto:akash@kloudle.com" class="dm-btn dm-email">akash@kloudle.com &nearr;</a>
      </div>

      <details class="form-details">
        <summary class="form-toggle">Or leave a message here</summary>
        <form class="contact-form" id="contact-form">
          <div class="field">
            <label for="contact-name" class="field-label">Name</label>
            <input type="text" id="contact-name" name="name" required placeholder="Your name" class="field-input" autocomplete="name" />
          </div>

          <div class="field">
            <label for="contact-email" class="field-label">Email</label>
            <input type="email" id="contact-email" name="email" required placeholder="you@example.com" class="field-input" autocomplete="email" />
          </div>

          <div class="field">
            <label for="contact-message" class="field-label">Message</label>
            <textarea id="contact-message" name="message" required placeholder="What are you working on?" class="field-input field-textarea" rows="4"></textarea>
          </div>

          <input type="text" name="hp_field" style="display:none" tabindex="-1" autocomplete="off" />

          <button type="submit" class="submit-btn">
            <span class="submit-text">Send message</span>
          </button>
        </form>
      </details>

      <div class="success" id="form-success" hidden>
        <p class="success-text">Sent. I'll get back to you.</p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    if (data.get('hp_field')) return;

    const name = data.get('name') as string;
    const email = data.get('email') as string;
    const message = data.get('message') as string;
    if (!name || !email || !message) return;

    const button = form.querySelector('.submit-btn') as HTMLButtonElement;
    const btnText = button.querySelector('.submit-text') as HTMLSpanElement;
    const originalText = btnText.textContent;
    btnText.textContent = 'Sending...';
    button.disabled = true;

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message, source: window.location.pathname, hp: data.get('hp_field') || '' }),
      });
      if (!res.ok) throw new Error('Request failed');

      const details = form.closest('details');
      if (details) details.removeAttribute('open');
      if (success) success.hidden = false;
    } catch {
      btnText.textContent = originalText;
      button.disabled = false;
    }
  });
</script>

<style>
  .contact { padding: 6rem var(--gutter); }
  .contact-inner { max-width: 36rem; margin: 0 auto; }

  .contact-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 3rem 2.5rem;
  }

  .contact-heading {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .contact-sub {
    font-size: 0.925rem;
    color: var(--color-text-dim);
    margin-bottom: 1.5rem;
  }

  .contact-quick {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .dm-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.25rem;
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-sans), system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    transition: background 0.15s;
  }
  .dm-btn:hover { background: var(--color-accent-hover); color: #fff; }

  .dm-email {
    background: transparent;
    border: 1px solid var(--color-border-light);
    color: var(--color-text-dim);
  }
  .dm-email:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: transparent;
  }

  .form-details { border-top: 1px solid var(--color-border); padding-top: 1.5rem; }

  .form-toggle {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-dim);
    cursor: pointer;
    list-style: none;
    margin-bottom: 1.5rem;
    display: block;
  }
  .form-toggle::-webkit-details-marker { display: none; }
  .form-toggle::before { content: '+ '; color: var(--color-accent); }
  details[open] .form-toggle::before { content: '- '; }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1.25rem;
  }

  .field { display: flex; flex-direction: column; gap: 0.4rem; }

  .field-label {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  .field-input {
    padding: 0.8rem 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .field-input:focus { border-color: var(--color-accent); }
  .field-input::placeholder { color: var(--color-text-dim); opacity: 0.4; }

  .field-textarea { resize: vertical; min-height: 100px; line-height: 1.65; }

  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 2rem;
    background: var(--color-accent);
    color: #fff;
    border: none;
    font-family: var(--font-sans), system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.15s;
    width: 100%;
  }
  .submit-btn:hover { background: var(--color-accent-hover); }
  .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .success[hidden] { display: none; }
  .success { text-align: center; padding: 2rem 0; }
  .success-text { font-size: 1rem; font-weight: 500; color: var(--color-text); }

  @media (max-width: 480px) {
    .contact-card { padding: 2rem 1.5rem; }
  }
</style>
