---
const projectCount = 26;
---

<section class="hero">
  <div class="hero-inner">
    <p class="section-label reveal">Akash Mahajan</p>

    <h1 class="hero-title reveal reveal-d1">
      Security for AI.<br />
      <span class="hero-accent">Secure infra for agents.</span>
    </h1>

    <p class="hero-desc reveal reveal-d2">
      24 years in cybersecurity. From writing Snort IDS signatures to
      co-founding India's largest open security community. Now building
      the tools that keep your AI agents, LLM-powered apps, and agentic
      infrastructure safe.
    </p>

    <div class="hero-companies reveal reveal-d2">
      <a href="https://kloudle.com" target="_blank" rel="noopener" class="hero-company">
        <span class="hc-name">Kloudle</span>
        <span class="hc-desc">Cloud security scanning for teams shipping with AI agents</span>
      </a>
      <a href="https://appsecco.com" target="_blank" rel="noopener" class="hero-company">
        <span class="hc-name">Appsecco</span>
        <span class="hc-desc">Product security testing for apps, APIs, and AI integrations</span>
      </a>
    </div>

    <div class="hero-stats reveal reveal-d3">
      <div class="stat">
        <span class="stat-number">24</span>
        <span class="stat-label">Years in Security</span>
      </div>
      <div class="stat">
        <span class="stat-number">4</span>
        <span class="stat-label">Companies Founded</span>
      </div>
      <div class="stat">
        <span class="stat-number">{projectCount}</span>
        <span class="stat-label">Active Projects</span>
      </div>
      <div class="stat">
        <span class="stat-number">2</span>
        <span class="stat-label">Books Published</span>
      </div>
    </div>

    <div class="hero-proof reveal reveal-d3">
      <p>Books recommended by PortSwigger. Published by Packt. Co-founded <a href="https://null.community" target="_blank" rel="noopener">null</a>, India's open security community — 11 years, 6 cities.</p>
    </div>

    <div class="hero-actions reveal reveal-d3">
      <a href="#projects" class="btn-primary">See what I'm building <span class="btn-arrow">&darr;</span></a>
      <a href="/about" class="btn-secondary">The full story</a>
    </div>

    <div class="hero-follow reveal reveal-d3">
      <span class="follow-label">Follow</span>
      <div class="follow-links">
        <a href="https://x.com/makash" target="_blank" rel="noopener">X</a>
        <a href="https://www.linkedin.com/in/akashm/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://github.com/makash" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.youtube.com/@makash" target="_blank" rel="noopener">YouTube</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: 10rem var(--gutter) 6rem;
  }

  .hero-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    width: 100%;
  }

  .hero-title {
    font-size: clamp(3rem, 7vw, 5.5rem);
    color: var(--color-text);
    margin-bottom: 1.5rem;
    max-width: 52rem;
  }

  .hero-accent {
    color: var(--color-accent);
  }

  .hero-desc {
    font-size: clamp(1.05rem, 1rem + 0.25vw, 1.2rem);
    color: var(--color-text-dim);
    max-width: 38rem;
    margin-bottom: 2rem;
    line-height: 1.85;
  }

  /* Companies strip */
  .hero-companies {
    display: flex;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
    max-width: 38rem;
  }

  .hero-company {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    color: var(--color-text);
    transition: background 0.15s;
  }
  .hero-company:hover { background: var(--color-surface-hover); color: var(--color-text); }

  .hc-name {
    font-family: var(--font-display), Georgia, serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .hc-desc {
    font-size: 0.8rem;
    color: var(--color-text-dim);
    line-height: 1.5;
  }

  /* Stats */
  .hero-stats {
    display: flex;
    gap: 3rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    max-width: fit-content;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: var(--font-display), Georgia, serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Proof */
  .hero-proof {
    margin-bottom: 2.5rem;
    max-width: 38rem;
  }

  .hero-proof p {
    font-size: 0.9rem;
    color: var(--color-text-dim);
    line-height: 1.7;
  }

  .hero-proof a {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-border-light);
    text-underline-offset: 3px;
  }
  .hero-proof a:hover {
    text-decoration-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Actions */
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-sans), system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.15s ease;
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }
  .btn-arrow { transition: transform 0.15s; }
  .btn-primary:hover .btn-arrow { transform: translateY(2px); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2rem;
    border: 1px solid var(--color-border-light);
    color: var(--color-text-dim);
    font-family: var(--font-sans), system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.15s ease;
  }
  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Follow strip */
  .hero-follow {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .follow-label {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .follow-links {
    display: flex;
    gap: 1.25rem;
  }

  .follow-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-dim);
    transition: color 0.15s;
  }
  .follow-links a:hover { color: var(--color-accent); }

  @media (max-width: 640px) {
    .hero { min-height: auto; padding: 8rem var(--gutter) 4rem; }
    .hero-stats { gap: 2rem; flex-wrap: wrap; }
    .stat-number { font-size: 1.75rem; }
    .hero-companies { flex-direction: column; }
  }
</style>
