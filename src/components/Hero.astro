---
const projectCount = 16;
---

<section class="hero">
  <div class="hero-inner">
    <p class="section-label reveal">Akash Mahajan</p>

    <h1 class="hero-title reveal reveal-d1">
      I build security tools<br />
      <span class="hero-accent">that people actually use.</span>
    </h1>

    <p class="hero-desc reveal reveal-d2">
      Founder of two security companies. {projectCount} active projects spanning
      cloud security, AI agents, developer tools, and education.
      I ship fast and I ship in the open.
    </p>

    <div class="hero-stats reveal reveal-d3">
      <div class="stat">
        <span class="stat-number">2</span>
        <span class="stat-label">Companies</span>
      </div>
      <div class="stat">
        <span class="stat-number">{projectCount}</span>
        <span class="stat-label">Projects</span>
      </div>
      <div class="stat">
        <span class="stat-number">2</span>
        <span class="stat-label">Books</span>
      </div>
      <div class="stat">
        <span class="stat-number">10+</span>
        <span class="stat-label">Open Source</span>
      </div>
    </div>

    <div class="hero-actions reveal reveal-d3">
      <a href="#projects" class="btn-primary">See what I'm building <span class="btn-arrow">&darr;</span></a>
      <a href="/about" class="btn-secondary">About me</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: 10rem var(--gutter) 6rem;
  }

  .hero-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    width: 100%;
  }

  .hero-title {
    font-size: clamp(3rem, 7vw, 5.5rem);
    color: var(--color-text);
    margin-bottom: 2rem;
    max-width: 52rem;
  }

  .hero-accent {
    color: var(--color-accent);
  }

  .hero-desc {
    font-size: clamp(1.05rem, 1rem + 0.25vw, 1.2rem);
    color: var(--color-text-dim);
    max-width: 36rem;
    margin-bottom: 3rem;
    line-height: 1.85;
  }

  .hero-stats {
    display: flex;
    gap: 3rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
    max-width: fit-content;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: var(--font-display), Georgia, serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-sans), system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.15s ease;
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }
  .btn-arrow { transition: transform 0.15s; }
  .btn-primary:hover .btn-arrow { transform: translateY(2px); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2rem;
    border: 1px solid var(--color-border-light);
    color: var(--color-text-dim);
    font-family: var(--font-sans), system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.15s ease;
  }
  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .hero { min-height: auto; padding: 8rem var(--gutter) 4rem; }
    .hero-stats { gap: 2rem; flex-wrap: wrap; }
    .stat-number { font-size: 1.75rem; }
  }
</style>
